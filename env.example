# HUBSPOT
HUBSPOT_API_TOKEN=your_hubspot_api_token_here
HUBSPOT_PORTAL_ID=your_portal_id_here
HUBDB_TABLE_ID=your_hubdb_table_id_here

# MYSQL
# Valores de ejemplo (no se deben commitear credenciales reales)
# Para Railway, estos valores suelen lucir así:
#   MYSQL_HOST=mainline.proxy.rlwy.net
#   MYSQL_PORT=57262
#   MYSQL_USER=root
#   MYSQL_PASSWORD=tu_password_aqui
#   MYSQL_DATABASE=railway
#   MYSQL_TABLE=diplomados
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name
MYSQL_TABLE=your_table_name

# SERVER
PORT=3000
NODE_ENV=development

